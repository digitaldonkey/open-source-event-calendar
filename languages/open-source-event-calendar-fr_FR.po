#. translators: 1: Filename 2: ABSPATH 3: OSEC_FILE_CACHE_WP_UPLOAD_DIR 4: OSEC_FILE_CACHE_DEFAULT_PATH
#: src/Cache/CacheFile.php:232
msgid ""
"Can not use WP_Filesystem() method to write to file: %1$s\n"
"                        <br /><br />\n"
"                        You may set OSEC_ENABLE_CACHE_FILE false to use "
"other cache methods like APCU or DB and ignore this message.\n"
"                        <br /><br /><strong>BUT: If we can not write files "
"Twig cache is disabled.</strong>\n"
"                        <br /><br /><strong>Ensure that</strong><br /><code>"
"%2$swp-content/uploads/%3$s\n"
"                        </code><br />or<br /><code>%4$</code><br /> are "
"writable by php."
msgstr ""
"Impossible d&#39;utiliser la méthode WP_Filesystem() pour écrire dans le "
"fichier : %1$s<br /><br /> Vous pouvez définir OSEC_ENABLE_CACHE_FILE sur "
"false pour utiliser d&#39;autres méthodes de cache comme APCU ou DB et "
"ignorer ce message.<br /><br /> <strong>MAIS : Si nous ne pouvons pas écrire "
"de fichiers, le cache Twig est désactivé.</strong><br /><br /> <strong>"
"Assurez-vous que</strong><br /> <code>%2$swp-content/uploads/%3$s</code><br "
"/> ou<br /> <code>%4$</code><br /> sont accessibles en écriture par PHP."

