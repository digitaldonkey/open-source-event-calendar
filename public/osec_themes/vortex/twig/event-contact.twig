<div class="osec-event-contact h-card" itemprop="organizer" itemscope itemtype="https://schema.org/Person">
        {% if contact_name %}
        <div class="contact-name p-name" itemprop="name">
                <i class="ai1ec-fa ai1ec-fa-fw ai1ec-fa-user"></i>
                {{ contact_name }}
        </div>
        {% endif %}

        {% if contact_phone %}
        <div class="contact-phone p-tel">
                <i class="ai1ec-fa ai1ec-fa-fw ai1ec-fa-phone"></i>
                <a class="action-link" itemprop="telephone" href="tel:{{ contact_phone }}">{{ contact_phone }}</a>
        </div>
        {% endif %}

        {% if contact_email %}
                <div class="contact-email">
                        <i class="ai1ec-fa ai1ec-fa-fw ai1ec-fa-envelope-o"></i>
                        <a class="u-email action-link" href="mailto:{{ contact_email }}" itemprop="email">
                                {{ contact_email_text }}
                        </a>
                </div>
        {% endif %}

        {% if contact_url %}
                <div class="contact-url">
                        {#~ 1.28571429em ? @see .ai1ec-fa-fw ~#}
                        <svg style="vertical-align: middle" width="1.28571429em" height="1.28571429em"
                             viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" stroke-width="3" stroke="currentColor"
                             fill="none">
                                <path d="M39.93,55.72A24.86,24.86,0,1,1,56.86,32.15a37.24,37.24,0,0,1-.73,6" />
                                <path d="M37.86,51.1A47,47,0,0,1,32,56.7" />
                                <path d="M32,7A34.14,34.14,0,0,1,43.57,30a34.07,34.07,0,0,1,.09,4.85" />
                                <path d="M32,7A34.09,34.09,0,0,0,20.31,32.46c0,16.2,7.28,21,11.66,24.24" />
                                <line x1="10.37" y1="19.9" x2="53.75" y2="19.9" />
                                <line x1="32" y1="6.99" x2="32" y2="56.7" />
                                <line x1="11.05" y1="45.48" x2="37.04" y2="45.48" />
                                <line x1="7.14" y1="32.46" x2="56.86" y2="31.85" />
                                <path d="M53.57,57,58,52.56l-8-8,4.55-2.91a.38.38,0,0,0-.12-.7L39.14,37.37a.39.39,0,0,0-.46.46L42,53.41a.39.39,0,0,0,.71.13L45.57,49Z" />
                        </svg>
                        <a class="u-url action-link" target="_blank" href="{{ contact_url }}" itemprop="url">
                                {{ contact_url_text }}
                                <i class="ai1ec-fa ai1ec-fa-external-link"></i>
                        </a>
                </div>
        {% endif %}
</div>
