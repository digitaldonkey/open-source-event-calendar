<div class="plana-pagination">
	{% for link in links %}
		{% if link is iterable %}
			{% set tag =  link.enabled ? "a" : "button" %}
			<{{ tag }}  class="{{ link.class }} ai1ec-load-view action-link {% if not link.enabled %}ai1ec-disabled{% endif %}"
				{{ data_type | raw }}
				{% if not link.enabled %}
					disabled="disabled"
				{% else %}
					href="{{ link.href | e('html_attr') }}"
				{% endif %}>
				{{ link.text | raw }}
			</{{ tag }}>
		{% else %}
			{{ link | raw }}
		{% endif %}
	{% endfor %}
</div>
